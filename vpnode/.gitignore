# ── Private keys - NEVER commit ──────────────────────────────────
keys/
# public but still ignore it:
initramfs/etc/ospkg_signing_root.pem

# ── Pi flash - keep only config files ────────────────────────────
pi-flash/kernel8.img
pi-flash/rootfs.squash
pi-flash/boot.json
pi-flash/initramfs.cpio.gz
