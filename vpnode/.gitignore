# ── Private keys - NEVER commit ──────────────────────────────────
signing.key
*.key
!signing.pub
!keys/*.pub

# ── Generated build artifacts ────────────────────────────────────
rootfs.squash
boot.img
boot.json
hash.txt
signature.bin
initramfs.cpio.gz

# ── Large downloadable/rebuildable sources ───────────────────────
linux/
busybox-*/
openssl-*/
alpine-make-rootfs
*.tar
*.tar.gz
*.tar.bz2

